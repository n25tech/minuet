# For your main HTML and root paths (forces immediate check)
/
  Cache-Control: no-cache, no-store, must-revalidate
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# For your Service Worker script (CRITICAL: must never be cached by headers)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Static assets are NOT content-hashed, so they must be revalidated on each load.
# (Marking them immutable froze old CSS/JS in browsers for a year after deploys.)
/assets/*
  Cache-Control: public, max-age=0, must-revalidate
/js/*
  Cache-Control: public, max-age=0, must-revalidate
